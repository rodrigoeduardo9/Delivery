# =============================================
# Delivery Platform - Environment Variables
# =============================================

# Application
NODE_ENV=development
BACKEND_PORT=3000
ADMIN_PORT=5173
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Database (PostgreSQL + PostGIS)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=delivery_db
DB_USER=delivery_user
DB_PASSWORD=delivery_pass

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=delivery_redis_pass

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Firebase Cloud Messaging
FCM_SERVICE_ACCOUNT_PATH=./docker/secrets/fcm_service_account.json

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Payment Gateways
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
MERCADO_PAGO_ACCESS_TOKEN=TEST_your_mercadopago_token
MERCADO_PAGO_PUBLIC_KEY=TEST_your_mercadopago_public_key

# Email (SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@delivery.local

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
